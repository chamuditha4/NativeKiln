// Native Kiln — data model. See CLAUDE.md "Domain model".
// All timestamps are stored and returned in UTC. IDs are opaque, prefixed
// strings generated by the application (see @native-kiln/shared generateId),
// so database sequences are never exposed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Platform {
  ANDROID
  IOS
}

enum Framework {
  EXPO
  REACT_NATIVE
  FLUTTER
  NATIVE_ANDROID
  NATIVE_IOS
}

enum BuildProfileType {
  DEVELOPMENT
  PREVIEW
  PRODUCTION
}

enum ArtifactType {
  APK
  AAB
  IPA
}

enum CredentialType {
  ANDROID_KEYSTORE
  GOOGLE_SERVICE_ACCOUNT
  APPLE_API_KEY
  APPLE_DISTRIBUTION_CERT
  APPLE_PROVISIONING_PROFILE
  REPOSITORY_TOKEN
  GENERIC
}

enum BuildState {
  QUEUED
  ASSIGNED
  PREPARING
  CLONING
  INSTALLING
  PREBUILDING
  COMPILING
  SIGNING
  UPLOADING
  SUCCEEDED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum SubmissionState {
  QUEUED
  UPLOADING
  PROCESSING
  READY
  SUBMITTING
  SUBMITTED
  APPROVED
  REJECTED
  FAILED
}

enum SubmissionStore {
  GOOGLE_PLAY
  APP_STORE
}

enum RunnerStatus {
  ONLINE
  OFFLINE
  BUSY
  DISABLED
}

// ----------------------------------------------------------------------------
// Auth
// ----------------------------------------------------------------------------

model User {
  id           String    @id
  email        String    @unique
  // Argon2id hash. Never expose.
  passwordHash String
  displayName  String?
  isAdmin      Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     Session[]
  auditEvents  AuditEvent[]

  @@map("users")
}

model Session {
  id           String   @id
  userId       String
  // SHA-256 of the session token; the raw token lives only in the cookie.
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ----------------------------------------------------------------------------
// Projects
// ----------------------------------------------------------------------------

model Project {
  id              String    @id
  slug            String    @unique
  name            String
  framework       Framework
  androidPackageId String?
  appleBundleId   String?
  // Per-project artifact retention override; falls back to global default.
  retentionDays   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  source          ProjectSource?
  buildProfiles   BuildProfile[]
  environmentVars EnvironmentVariable[]
  credentials     Credential[]
  builds          Build[]
  submissions     Submission[]

  @@map("projects")
}

model ProjectSource {
  id            String   @id
  projectId     String   @unique
  // e.g. "https://github.com/owner/repo.git"
  repositoryUrl String
  defaultBranch String   @default("main")
  // Reference (by name) to a REPOSITORY_TOKEN credential; never the token itself.
  credentialId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_sources")
}

model BuildProfile {
  id             String           @id
  projectId      String
  name           String
  type           BuildProfileType
  platform       Platform
  // Requested artifact for Android profiles (APK/AAB); null for iOS.
  artifactType   ArtifactType?
  autoIncrement  Boolean          @default(false)
  // Free-form, validated JSON of allowed build fields (scheme, configuration...).
  config         Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  builds         Build[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("build_profiles")
}

model EnvironmentVariable {
  id          String   @id
  projectId   String
  key         String
  // Encrypted value payload (AES-256-GCM). Never returned decrypted to browser.
  keyVersion  Int
  nonce       String
  ciphertext  String
  authTag     String
  // Non-secret vars may be marked so, but values are still encrypted at rest.
  isSecret    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
  @@map("environment_variables")
}

model Credential {
  id          String         @id
  // Global credential when projectId is null.
  projectId   String?
  name        String
  type        CredentialType
  // Encrypted payload (AES-256-GCM).
  keyVersion  Int
  nonce       String
  ciphertext  String
  authTag     String
  // Safe, non-secret metadata (e.g. cert fingerprint, key id). No secrets.
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@index([type])
  @@map("credentials")
}

// ----------------------------------------------------------------------------
// Builds
// ----------------------------------------------------------------------------

model Build {
  id            String     @id
  projectId     String
  buildProfileId String
  platform      Platform
  state         BuildState @default(QUEUED)
  // The requested ref (branch/tag/sha) and the resolved commit SHA.
  requestedRef  String
  commitSha     String?
  // Monotonic per-project build number.
  buildNumber   Int
  // Idempotency key so duplicate queue delivery cannot start two builds.
  idempotencyKey String    @unique
  runnerId      String?
  // Last meaningful error message (redacted), preserved on failure.
  errorMessage  String?
  // Durable reference to the full log object in MinIO (bucket/key).
  logObjectKey  String?
  queuedAt      DateTime   @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  buildProfile  BuildProfile @relation(fields: [buildProfileId], references: [id])
  runner        Runner?      @relation(fields: [runnerId], references: [id])
  steps         BuildStep[]
  logChunks     BuildLogChunk[]
  artifacts     Artifact[]
  submissions   Submission[]

  @@unique([projectId, buildNumber])
  @@index([projectId])
  @@index([state])
  @@index([runnerId])
  @@map("builds")
}

model BuildStep {
  id         String     @id
  buildId    String
  name       String
  state      BuildState
  sequence   Int
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime   @default(now())

  build      Build      @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([buildId, sequence])
  @@index([buildId])
  @@map("build_steps")
}

// Short-lived, live-streaming log chunks. The durable full log lives in MinIO
// (Build.logObjectKey); these support live tailing and are pruned after upload.
model BuildLogChunk {
  id        String   @id
  buildId   String
  sequence  Int
  // Already redacted before persistence.
  content   String
  createdAt DateTime @default(now())

  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([buildId, sequence])
  @@index([buildId, sequence])
  @@map("build_log_chunks")
}

model Artifact {
  id          String       @id
  buildId     String
  platform    Platform
  type        ArtifactType
  // Object storage key (MinIO). Downloads use presigned URLs.
  objectKey   String
  sizeBytes   BigInt
  sha256      String
  buildNumber Int
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())

  build       Build        @relation(fields: [buildId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([buildId])
  @@index([expiresAt])
  @@map("artifacts")
}

// ----------------------------------------------------------------------------
// Runners
// ----------------------------------------------------------------------------

model Runner {
  id            String       @id
  name          String
  platform      Platform
  status        RunnerStatus @default(OFFLINE)
  // Hash of the long-lived runner credential; raw token never stored.
  tokenHash     String       @unique
  version       String?
  concurrency   Int          @default(1)
  currentBuildId String?
  lastHeartbeat DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  capabilities  RunnerCapability[]
  builds        Build[]

  @@index([platform])
  @@index([status])
  @@map("runners")
}

model RunnerCapability {
  id        String   @id
  runnerId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runner    Runner   @relation(fields: [runnerId], references: [id], onDelete: Cascade)

  @@unique([runnerId, key])
  @@index([runnerId])
  @@map("runner_capabilities")
}

// One-time tokens an admin creates to register a new runner.
model RunnerRegistrationToken {
  id         String    @id
  tokenHash  String    @unique
  name       String
  platform   Platform
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  usedAt     DateTime?

  @@map("runner_registration_tokens")
}

// ----------------------------------------------------------------------------
// Submissions
// ----------------------------------------------------------------------------

model Submission {
  id            String          @id
  projectId     String
  buildId       String
  artifactId    String
  store         SubmissionStore
  // e.g. "internal", "production" for Play; TestFlight group for Apple.
  track         String?
  state         SubmissionState @default(QUEUED)
  releaseStatus String?
  rolloutPercent Int?
  // External identifiers returned by the store provider.
  externalBuildId   String?
  externalVersionId String?
  // Redacted provider response payload.
  providerResponse  Json?
  // Idempotency key so a version is never submitted twice.
  idempotencyKey String  @unique
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  build         Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)
  artifact      Artifact @relation(fields: [artifactId], references: [id])

  @@index([projectId])
  @@index([buildId])
  @@index([state])
  @@map("submissions")
}

// ----------------------------------------------------------------------------
// Audit
// ----------------------------------------------------------------------------

model AuditEvent {
  id         String   @id
  // Null for system-originated events.
  userId     String?
  action     String
  targetType String?
  targetId   String?
  // Safe, redacted context only. Never secrets.
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_events")
}
